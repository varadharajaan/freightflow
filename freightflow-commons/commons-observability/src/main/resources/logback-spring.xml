<?xml version="1.0" encoding="UTF-8"?>
<!--
    FreightFlow Logback Configuration
    ==================================
    Production-grade structured logging with:
    - JSON output for production (ELK-compatible via logstash-logback-encoder)
    - Human-readable console output for local development
    - Rolling file appender (time-based daily + size-based 100MB cap)
    - MDC fields: correlationId, tenantId, userId, serviceName
    - Log levels: ERROR > WARN > INFO > DEBUG > TRACE
    - NEVER logs sensitive data (PII, tokens, passwords)
-->
<configuration scan="true" scanPeriod="30 seconds">

    <!-- ==================== Properties ==================== -->
    <property name="LOG_DIR" value="${LOG_DIR:-logs}"/>
    <property name="SERVICE_NAME" value="${SERVICE_NAME:-freightflow}"/>
    <property name="LOG_MAX_FILE_SIZE" value="100MB"/>
    <property name="LOG_MAX_HISTORY" value="30"/>
    <property name="LOG_TOTAL_SIZE_CAP" value="3GB"/>

    <!-- ==================== Console Appender (Local Dev) ==================== -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>
                %d{yyyy-MM-dd HH:mm:ss.SSS} %highlight(%-5level) [%thread] [%X{correlationId:-}] %cyan(%-40.40logger{39}) : %msg%n
            </pattern>
        </encoder>
    </appender>

    <!-- ==================== Rolling File Appender ==================== -->
    <!--
        Time-based rollover: daily files (freightflow.2026-03-27.log)
        Size-based rollover: max 100MB per file (freightflow.2026-03-27.0.log.gz)
        Retention: 30 days, total cap 3GB
        Compressed: gzip after rollover
    -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/${SERVICE_NAME}.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/archived/${SERVICE_NAME}.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>${LOG_MAX_FILE_SIZE}</maxFileSize>
            <maxHistory>${LOG_MAX_HISTORY}</maxHistory>
            <totalSizeCap>${LOG_TOTAL_SIZE_CAP}</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>
                %d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] [correlationId=%X{correlationId:-}] [tenantId=%X{tenantId:-}] [userId=%X{userId:-}] %logger{36} : %msg%n
            </pattern>
        </encoder>
    </appender>

    <!-- ==================== JSON File Appender (Production) ==================== -->
    <!--
        Structured JSON logging for ELK stack (Elasticsearch + Logstash + Kibana).
        Uses logstash-logback-encoder for automatic JSON formatting.
        MDC fields are included as top-level JSON fields.
    -->
    <appender name="JSON_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/${SERVICE_NAME}-json.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/archived/${SERVICE_NAME}-json.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>${LOG_MAX_FILE_SIZE}</maxFileSize>
            <maxHistory>${LOG_MAX_HISTORY}</maxHistory>
            <totalSizeCap>${LOG_TOTAL_SIZE_CAP}</totalSizeCap>
        </rollingPolicy>
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <includeMdcKeyName>correlationId</includeMdcKeyName>
            <includeMdcKeyName>tenantId</includeMdcKeyName>
            <includeMdcKeyName>userId</includeMdcKeyName>
            <includeMdcKeyName>serviceName</includeMdcKeyName>
            <customFields>{"service":"${SERVICE_NAME}"}</customFields>
            <timestampPattern>yyyy-MM-dd'T'HH:mm:ss.SSS'Z'</timestampPattern>
        </encoder>
    </appender>

    <!-- ==================== Async Wrapper for File Appenders ==================== -->
    <!-- Non-blocking file writes to prevent logging from impacting request latency -->
    <appender name="ASYNC_FILE" class="ch.qos.logback.classic.AsyncAppender">
        <appender-ref ref="FILE"/>
        <queueSize>1024</queueSize>
        <discardingThreshold>0</discardingThreshold>
        <includeCallerData>false</includeCallerData>
    </appender>

    <appender name="ASYNC_JSON" class="ch.qos.logback.classic.AsyncAppender">
        <appender-ref ref="JSON_FILE"/>
        <queueSize>1024</queueSize>
        <discardingThreshold>0</discardingThreshold>
        <includeCallerData>false</includeCallerData>
    </appender>

    <!-- ==================== Logger Configuration ==================== -->

    <!-- FreightFlow application loggers -->
    <logger name="com.freightflow" level="DEBUG"/>

    <!-- Spring framework (INFO in production, DEBUG for troubleshooting) -->
    <logger name="org.springframework" level="INFO"/>
    <logger name="org.springframework.web" level="INFO"/>
    <logger name="org.springframework.security" level="INFO"/>

    <!-- Hibernate / JPA -->
    <logger name="org.hibernate" level="WARN"/>
    <logger name="org.hibernate.SQL" level="DEBUG"/>
    <logger name="org.hibernate.type.descriptor.sql.BasicBinder" level="TRACE"/>

    <!-- Kafka -->
    <logger name="org.apache.kafka" level="WARN"/>
    <logger name="org.springframework.kafka" level="INFO"/>

    <!-- HikariCP connection pool -->
    <logger name="com.zaxxer.hikari" level="INFO"/>
    <logger name="com.zaxxer.hikari.HikariConfig" level="DEBUG"/>

    <!-- Flyway migrations -->
    <logger name="org.flywaydb" level="INFO"/>

    <!-- Resilience4j -->
    <logger name="io.github.resilience4j" level="INFO"/>

    <!-- ==================== Profile-based Root Logger ==================== -->

    <!-- Default: local development (console + rolling file) -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="ASYNC_FILE"/>
    </root>

    <!-- Production profile: JSON logging only (no console) -->
    <springProfile name="prod,staging">
        <root level="INFO">
            <appender-ref ref="ASYNC_JSON"/>
        </root>
        <!-- Reduce noise in production -->
        <logger name="com.freightflow" level="INFO"/>
        <logger name="org.hibernate.SQL" level="WARN"/>
        <logger name="org.hibernate.type.descriptor.sql.BasicBinder" level="WARN"/>
    </springProfile>

    <!-- Local development: human-readable console + file -->
    <springProfile name="local">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="ASYNC_FILE"/>
        </root>
        <logger name="com.freightflow" level="DEBUG"/>
    </springProfile>

</configuration>
